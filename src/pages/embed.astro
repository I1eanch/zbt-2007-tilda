---
// Вариант лендинга для встраивания в Tilda через iframe (блок T123).
// Композиция секций совпадает с `index.astro` (contract: те же 11 модулей в том
// же порядке; парити проверяется в tests/embed.spec.ts), но site-chrome с
// `position: fixed` (Header, StickyCTA) намеренно не рендерится: в auto-resize
// iframe он не может залипать. Модалка регистрации сохранена — родительский
// T123-скрипт делает iframe fixed-fullscreen на время её открытия.
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Hook from '../components/Hook.astro';
import Audience from '../components/Audience.astro';
import DualValue from '../components/DualValue.astro';
import Program from '../components/Program.astro';
import CareerPath from '../components/CareerPath.astro';
import Stats from '../components/Stats.astro';
import Speaker from '../components/Speaker.astro';
import Bonuses from '../components/Bonuses.astro';
import Registration from '../components/Registration.astro';
import Footer from '../components/Footer.astro';
import RegistrationModal from '../components/RegistrationModal.astro';
---

<Layout
  title="Здоровье без таблеток: от диагноза к профессии"
  description="Бесплатный трёхдневный марафон школы нутрициологии «Ресурс»."
  embed
>
  <main>
    <Hero />
    <Hook />
    <Audience />
    <DualValue />
    <Program />
    <CareerPath />
    <Stats />
    <Speaker />
    <Bonuses />
    <Registration />
    <Footer />
  </main>
  <RegistrationModal />
</Layout>
