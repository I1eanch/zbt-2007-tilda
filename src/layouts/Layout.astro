---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  embed?: boolean;
}

const {
  title,
  description,
  image = '/og-image.svg',
  embed = false,
} = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
---

<html lang="ru" data-embed={embed ? 'true' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {!embed && canonical && <link rel="canonical" href={canonical} />}
    {embed && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <slot />
    {/*
      Single, central client bootstrap owned by the layout. Astro processes and
      bundles this framework <script> (no attributes, so it is not forced inline),
      runs the motion init exactly once, and — on the /embed route only, via
      initEmbedBridge's own data-embed self-gate — starts the Tilda iframe bridge
      (auto-resize + modal fullscreen relay). Cleanup is wired for view transitions.
    */}
    <script>
      import { initLandingMotion } from '../lib/motion';
      import { initEmbedBridge } from '../lib/embed';
      const cleanupMotion = initLandingMotion();
      const cleanupEmbed = initEmbedBridge();
      document.addEventListener(
        'astro:before-swap',
        () => {
          cleanupMotion();
          cleanupEmbed();
        },
        { once: true },
      );
    </script>
  </body>
</html>
